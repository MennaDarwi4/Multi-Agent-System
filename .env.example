# Copy to .env and fill in what you need. Everything is optional:
# with no keys the app runs in "offline" mode using extractive fallbacks.

# ---- LLM provider: groq | openai | anthropic | offline ----
LLM_PROVIDER=offline

# Groq (free tier, recommended for students) -> https://console.groq.com
GROQ_API_KEY=
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ---- generation params ----
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=60

# ---- retrieval / orchestration ----
MAX_CHARS_PER_SOURCE=20000
PARALLEL_WORKERS=4

# ---- ngrok (for public deployment) -> https://dashboard.ngrok.com ----
NGROK_AUTH_TOKEN=
STREAMLIT_PORT=8501

# ---- SMTP (optional, only if you want the EmailAgent to actually SEND) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
