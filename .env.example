# Copy to .env and fill in your Groq key. Without a key the app still runs,
# degrading to extractive (non-LLM) fallbacks.

# Groq (free tier, recommended for students) -> https://console.groq.com
GROQ_API_KEY=
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# ---- generation params ----
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=60

# ---- retrieval / orchestration ----
MAX_CHARS_PER_SOURCE=20000
PARALLEL_WORKERS=4

# ---- frontend -> backend wiring ----
# URL where the Streamlit app reaches the FastAPI backend.
BACKEND_URL=http://localhost:8000
BACKEND_TIMEOUT=600

# Optional shared secret. If set on the BACKEND, requests to /run and
# /send-email must carry a matching X-API-Key. The frontend sends it
# automatically when this is also set on the frontend. Strongly recommended when
# the backend is publicly reachable; leave blank for local dev.
BACKEND_API_KEY=

# ---- SMTP (optional, only if you want the EmailAgent to actually SEND) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
