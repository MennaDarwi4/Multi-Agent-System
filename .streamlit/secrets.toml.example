# Streamlit Community Cloud secrets for the FRONTEND.
# In the Streamlit Cloud app: Settings > Secrets, then paste these (with real
# values). Do NOT commit the real secrets.toml — it is gitignored.

# Public https URL of your deployed FastAPI backend (e.g. from Render).
BACKEND_URL = "https://your-backend.onrender.com"

# Must match BACKEND_API_KEY set on the backend (if you enabled the guard).
BACKEND_API_KEY = "change-me-to-a-long-random-string"

# How long the frontend waits for a pipeline run (seconds).
BACKEND_TIMEOUT = "600"
