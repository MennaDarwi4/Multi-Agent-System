# Streamlit Community Cloud secrets for Argus.
# In the app: Settings > Secrets, then paste these (with real values).
# Do NOT commit the real secrets.toml — it is gitignored.

# Groq LLM key -> https://console.groq.com  (without it, Argus uses fallbacks)
GROQ_API_KEY = "gsk_your_key_here"

# Optional: force the lightweight RAG retriever if the dense one is too heavy
# for Streamlit Cloud's memory. Values: "dense" (default) or "sparse".
# RAG_BACKEND = "sparse"

# Optional: sending the drafted email via Gmail SMTP (App Password required)
# SMTP_HOST = "smtp.gmail.com"
# SMTP_PORT = "587"
# SMTP_USER = "you@gmail.com"
# SMTP_PASSWORD = "your-16-char-app-password"
